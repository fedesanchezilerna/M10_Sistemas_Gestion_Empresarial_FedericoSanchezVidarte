<odoo>
  <data>
    <!-- Student Views -->
    <record model="ir.ui.view" id="view_school_student_tree">
      <field name="name">school.student.tree</field>
      <field name="model">school.student</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="last_name"/>
          <field name="id_number"/>
          <field name="birth_date"/>
          <field name="age"/>
          <field name="class_id"/>
          <field name="active"/>
        </list>
      </field>
    </record>

    <record model="ir.ui.view" id="view_school_student_form">
      <field name="name">school.student.form</field>
      <field name="model">school.student</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <group>
                <field name="name"/>
                <field name="last_name"/>
                <field name="id_number"/>
              </group>
              <group>
                <field name="birth_date" widget="date"/>
                <field name="age" readonly="1"/>
                <field name="class_id"/>
                <field name="active"/>
              </group>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- Class Views -->
    <record model="ir.ui.view" id="view_school_class_tree">
      <field name="name">school.class.tree</field>
      <field name="model">school.class</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="grade"/>
          <field name="tutor_id"/>
          <field name="student_number"/>
          <field name="date_begin"/>
          <field name="date_end"/>
        </list>
      </field>
    </record>

    <record model="ir.ui.view" id="view_school_class_form">
      <field name="name">school.class.form</field>
      <field name="model">school.class</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <group>
                <field name="name"/>
                <field name="grade"/>
                <field name="tutor_id"/>
              </group>
              <group>
                <field name="date_begin"/>
                <field name="date_end"/>
                <field name="student_number"/>
              </group>
            </group>
            <notebook>
              <page string="Students">
                <field name="student_ids">
                  <list>
                    <field name="name"/>
                    <field name="last_name"/>
                    <field name="id_number"/>
                    <field name="age"/>
                  </list>
                </field>
              </page>
              <page string="Description">
                <field name="description"/>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <!-- Event Views -->
    <record model="ir.ui.view" id="view_school_event_tree">
      <field name="name">school.event.tree</field>
      <field name="model">school.event</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="date"/>
          <field name="type"/>
          <field name="class_id"/>
        </list>
      </field>
    </record>

    <record model="ir.ui.view" id="view_school_event_form">
      <field name="name">school.event.form</field>
      <field name="model">school.event</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <group>
                <field name="name"/>
                <field name="date"/>
                <field name="type"/>
              </group>
              <group>
                <field name="class_id"/>
                <field name="students_ids" widget="many2many_tags"/>
              </group>
            </group>
            <group>
              <field name="description"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- Calendar View for Events -->
    <record model="ir.ui.view" id="view_school_event_calendar">
      <field name="name">school.event.calendar</field>
      <field name="model">school.event</field>
      <field name="arch" type="xml">
        <calendar string="School Events" date_start="date" color="type" mode="month">
          <field name="name"/>
          <field name="type"/>
          <field name="class_id"/>
        </calendar>
      </field>
    </record>

    <!-- Search View for Events -->
    <record model="ir.ui.view" id="view_school_event_search">
      <field name="name">school.event.search</field>
      <field name="model">school.event</field>
      <field name="arch" type="xml">
        <search string="Search Events">
          <field name="name"/>
          <field name="type"/>
          <field name="class_id"/>
          <separator/>
          <filter string="Absences" name="filter_absence" domain="[('type', '=', 'absence')]"/>
          <filter string="Delays" name="filter_delay" domain="[('type', '=', 'delay')]"/>
          <filter string="Congratulations" name="filter_congratulations" domain="[('type', '=', 'congratulations')]"/>
          <filter string="Behavior" name="filter_behavior" domain="[('type', '=', 'behavior')]"/>
          <separator/>
          <group expand="0" string="Group By">
            <filter string="By Class" name="groupby_class" context="{'group_by': 'class_id'}"/>
            <filter string="By Type" name="groupby_type" context="{'group_by': 'type'}"/>
            <filter string="By Date" name="groupby_date" context="{'group_by': 'date:month'}"/>
          </group>
        </search>
      </field>
    </record>

    <!-- Actions -->
    <record model="ir.actions.act_window" id="action_school_student">
      <field name="name">Students</field>
      <field name="res_model">school.student</field>
      <field name="view_mode">list,form</field>
    </record>

    <record model="ir.actions.act_window" id="action_school_class">
      <field name="name">Classes</field>
      <field name="res_model">school.class</field>
      <field name="view_mode">list,form</field>
    </record>

    <record model="ir.actions.act_window" id="action_school_event">
      <field name="name">Events</field>
      <field name="res_model">school.event</field>
      <field name="view_mode">list,form,calendar</field>
      <field name="search_view_id" ref="view_school_event_search"/>
    </record>

    <!-- Top menu -->
    <menuitem name="School" id="menu_school_root"/>

    <!-- Menu categories -->
    <menuitem name="Management" id="menu_school_management" parent="menu_school_root"/>

    <!-- Menu items -->
    <menuitem name="Students" id="menu_school_student" parent="menu_school_management"
              action="action_school_student"/>
    <menuitem name="Classes" id="menu_school_class" parent="menu_school_management"
              action="action_school_class"/>
    <menuitem name="Events" id="menu_school_event" parent="menu_school_management"
              action="action_school_event"/>

  </data>
</odoo>
