<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_employee_form_inherit_school" model="ir.ui.view">
            <field name="name">hr.employee.form.inherit.school</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="School" name="school">
                        <group>
                            <field name="is_teacher"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

        <record id="view_employee_search_inherit_school" model="ir.ui.view">
            <field name="name">hr.employee.search.inherit.school</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//search" position="inside">
                    <separator/>
                    <filter string="Profesores" name="filter_teachers" domain="[('is_teacher', '=', True)]"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
