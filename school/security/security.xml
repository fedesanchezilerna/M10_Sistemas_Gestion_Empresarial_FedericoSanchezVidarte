<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Categoría de módulo -->
        <record id="module_school_category" model="ir.module.category">
            <field name="name">School</field>
            <field name="description">Categoría de seguridad para el módulo School</field>
        </record>

        <!-- Grupo Docente -->
        <record id="group_school_docente" model="res.groups">
            <field name="name">Docente</field>
            <field name="category_id" ref="module_school_category"/>
        </record>

        <!-- Grupo Director -->
        <record id="group_school_director" model="res.groups">
            <field name="name">Director</field>
            <field name="category_id" ref="module_school_category"/>
            <field name="implied_ids" eval="[(4, ref('group_school_docente'))]"/>
        </record>

        <!-- Record Rule: hr.employee solo lectura -->
        <record id="rule_hr_employee_readonly" model="ir.rule">
            <field name="name">School: HR Employee Read Only</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_school_docente')), (4, ref('group_school_director'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
